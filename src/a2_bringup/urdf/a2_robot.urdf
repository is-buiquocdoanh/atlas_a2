<?xml version="1.0"?>
<robot name="atlas_a2">

  <!--
    Convention: base_link tại mặt đất (z=0 = mặt đất).
    Body đi lên, bánh xe có đáy chạm z=0.
  -->

  <!-- ===== BASE ===== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.13"/>  <!-- box center ở z=0.13, đáy box tại z=0.03 (cách đất 3cm) -->
      <geometry>
        <box size="0.8 0.41 0.2"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <!-- ===== BÁNH CHÍNH TRÁI (y dương) ===== -->
  <joint name="left_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.23 0.075"/>   <!-- z = wheel radius → đáy bánh chạm z=0 -->
  </joint>
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.05"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.15 0.15 0.15 1.0"/>
      </material>
    </visual>
  </link>

  <!-- ===== BÁNH CHÍNH PHẢI (y âm) ===== -->
  <joint name="right_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.23 0.075"/>
  </joint>
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.05"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>

  <!-- ===== BÁNH TỰ DO - 4 GÓC ===== -->
  <!-- z = caster radius → đáy bánh chạm z=0 -->
  <joint name="caster_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_fl"/>
    <origin xyz="0.32 0.16 0.03"/>
  </joint>
  <link name="caster_fl">
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
  </link>

  <joint name="caster_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_fr"/>
    <origin xyz="0.32 -0.16 0.03"/>
  </joint>
  <link name="caster_fr">
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="caster_rl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_rl"/>
    <origin xyz="-0.32 0.16 0.03"/>
  </joint>
  <link name="caster_rl">
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="caster_rr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_rr"/>
    <origin xyz="-0.32 -0.16 0.03"/>
  </joint>
  <link name="caster_rr">
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="gray"/>
    </visual>
  </link>

  <!-- ===== LASER ===== -->
  <joint name="base_laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.35 0 0.25" rpy="0 0 3.14159"/>  <!-- xoay 180° quanh Z vì lidar gắn ngược chiều robot -->
  </joint>
  <link name="laser">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.03"/>
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

</robot>
