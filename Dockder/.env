# ── ROS2 ──────────────────────────────────────────────────────────────────────
ROS_DOMAIN_ID=0

# ── Robot hardware ports (chỉnh theo cổng USB thực tế trên robot) ─────────────
# Xem thêm: src/a2_platform/config/ports.yaml
# Tạo udev rules để symlink cố định: /etc/udev/rules.d/99-atlas-a2.rules
DEV_USBCAN=/dev/usbcan
DEV_RPLIDAR=/dev/rplidar
DEV_CAMERA=/dev/video2
DEV_BATTERY=/dev/battery
DEV_ESP32=/dev/esp32
DEV_MAGNETIC=/dev/magnetic

# ── Kết nối từ PC App → Robot ─────────────────────────────────────────────────
ROBOT_HOST=192.168.1.100:8080

# ── X11 cho App (PC) ──────────────────────────────────────────────────────────
DISPLAY=:0
